{
  "server": {
    "host": "0.0.0.0",
    "port": 9000,
    "grpc_port": 9001,
    "read_timeout": "30s",
    "write_timeout": "30s"
  },
  "auth": {
    "default": "kerberos",
    "kerberos": {
      "enabled": true,
      "kdc_address": "dc-1.ald.company.lan:88",
      "realm": "ALD.COMPANY.LAN",
      "service_name": "HTTP/proxy.ald.company.lan",
      "keytab_path": "/etc/krb5.keytab"
    },
    "oauth2": {
      "enabled": false,
      "token_url": "https://oauth.example.com/token",
      "introspection_url": "https://oauth.example.com/introspect",
      "client_id": "proxy-client",
      "client_secret": "secret"
    },
    "oidc": {
      "enabled": false,
      "issuer_url": "https://oidc.example.com",
      "client_id": "proxy-client",
      "client_secret": "secret",
      "redirect_url": "https://proxy.example.com/callback"
    }
  },
  "ldap": {
    "host": "dc-1.ald.company.lan",
    "port": 389,
    "base_dn": "DC=ald,DC=company,DC=lan",
    "bind_dn": "CN=proxy-service,OU=ServiceAccounts,DC=ald,DC=company,DC=lan",
    "bind_password": "password",
    "user_search_filter": "(sAMAccountName=%s)",
    "mac_label_attribute": "msDS-AssignedAuthNPolicy",
    "host_search_filter": "(|(cn=%s)(dNSHostName=%s))",
    "use_tls": false,
    "insecure_skip_verify": false,
    "timeout": "10s"
  },
  "logging": {
    "level": "info",
    "format": "json",
    "output": "stdout"
  },
  "mac": {
    "enabled": true,
    "default_label": "",
    "enforce_on_l4": true,
    "allowed_labels": ["secret", "top-secret", "confidential", "public"],
    "header_name": "X-ALD-MAC-User"
  }
}
