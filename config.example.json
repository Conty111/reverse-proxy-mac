{
  "server": {
    "grpc_port": 9001,
    "host": "0.0.0.0"
  },
  "log": {
    "level": "info",
    "json_format": false
  },
  "kerberos": {
    "enabled": true,
    "keytab": "/etc/krb5.keytab",
    "service_principal": "HTTP/service.example.com@REALM",
    "ldap": {
      "tls": false,
      "port": 389,
      "host": "example.company.lan",
      "base_dn": "DC=example,DC=company,DC=lan",
      "user_filter": "(sAMAccountName=%s)"
    }
  }
}
